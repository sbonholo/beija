# Beija Backend — Environment Variables
#
# Full reference: docs/INFRASTRUCTURE.md
# Railway deploy steps: README-DEPLOY.md

# ─── Core ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# On Railway, set DATA_DIR=/app/data (matches the volume mount path).
# When DATA_DIR is set, SQLite lives at $DATA_DIR/beija.db and uploads at $DATA_DIR/uploads.
DATA_DIR=
# Used only when DATA_DIR is empty:
DATABASE_FILE=./data/beija.db
UPLOAD_DIR=./uploads

# Public origin used to build absolute upload URLs.
# Auto-filled from RAILWAY_PUBLIC_DOMAIN in production.
PUBLIC_URL=http://localhost:4000

# ─── Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
OTP_TTL_SECONDS=300
# Returns the OTP code in the response and accepts wildcard codes (000000/0000).
# Force to "false" in production.
DEV_RETURN_OTP=true

# ─── WhatsApp OTP ───────────────────────────────────────────────────────
# Provider: mock | twilio-whatsapp | zenvia-whatsapp
WHATSAPP_PROVIDER=mock

# Twilio (when WHATSAPP_PROVIDER=twilio-whatsapp)
# Sandbox FROM number is +14155238886; the "whatsapp:" prefix is added by the backend.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Zenvia (when WHATSAPP_PROVIDER=zenvia-whatsapp)
ZENVIA_TOKEN=
ZENVIA_FROM=

# ─── Cloudflare R2 (photo storage) ──────────────────────────────────────
# Leave all R2_* empty for local dev — the backend falls back to writing
# photos to UPLOAD_DIR.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_PUBLIC_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─── Redis (Socket.io adapter) ──────────────────────────────────────────
# Optional. When set, multiple backend instances can broadcast Socket.io
# events to each other. Single-instance dev doesn't need it.
REDIS_URL=

# ─── CORS ───────────────────────────────────────────────────────────────
# Comma-separated allowed origins. FRONTEND_URL is appended automatically.
# In dev, http://localhost:5173 and :4173 are always allowed.
CORS_ORIGINS=
FRONTEND_URL=

# Beija Backend — Environment Variables
#
# These values are also documented in railway.toml + README-DEPLOY.md.

# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production
OTP_TTL_SECONDS=300
# Returns the OTP code in the response and accepts "000000" as a wildcard.
# Auto-disabled when NODE_ENV=production unless you force it.
DEV_RETURN_OTP=true

# Persistence
# On Railway, set DATA_DIR=/app/data (matches the railway.toml volume mountPath).
# When DATA_DIR is set, SQLite lives at $DATA_DIR/beija.db and uploads at $DATA_DIR/uploads.
DATA_DIR=
# Used only when DATA_DIR is empty:
DATABASE_FILE=./data/beija.db
UPLOAD_DIR=./uploads

# Public origin for absolute upload URLs (auto-filled from RAILWAY_PUBLIC_DOMAIN if not set).
PUBLIC_URL=http://localhost:4000

# CORS
# Comma-separated list of allowed origins. The deployed frontend URL is auto-added
# from FRONTEND_URL. In dev, http://localhost:5173 is allowed automatically.
CORS_ORIGINS=
FRONTEND_URL=

# SMS provider (mock for MVP; swap to twilio/zenvia in production).
SMS_PROVIDER=mock

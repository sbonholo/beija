# Beija Frontend — Environment Variables

# Base URL of the Beija backend service.
# Leave empty in development to use the Vite dev proxy (http://localhost:4000).
# In production (Railway), set to the backend's Railway URL, e.g.:
#   VITE_API_URL=https://beija-backend-production.up.railway.app
VITE_API_URL=

# Optional override for the Socket.io endpoint.
# Defaults to VITE_API_URL when empty.
VITE_SOCKET_URL=

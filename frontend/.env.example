# Beija — env vars template
# Copy to .env.local and fill in real values. Never commit .env.local.

# -------- Supabase (REQUIRED) --------
# Find these at: https://supabase.com/dashboard/project/<project-ref>/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...your-anon-public-key

# -------- Google Sign In (REQUIRED for native iOS/Android) --------
# Created at https://console.cloud.google.com → APIs & Services → Credentials
# - iOS OAuth client: matches your iOS bundle id (io.beija.app)
# - Web OAuth client: used by Supabase Auth + web fallback
VITE_GOOGLE_IOS_CLIENT_ID=000000000000-xxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_WEB_CLIENT_ID=000000000000-yyyyyyyy.apps.googleusercontent.com

# -------- Seed script (LOCAL DEV ONLY — never set in prod env) --------
# Required by `npm run db:seed` to bypass RLS when creating 50 fake profiles.
# Find at: https://supabase.com/dashboard/project/<project-ref>/settings/api
# WARNING: full DB access. Keep .env.local out of git.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# -------- Observability (FASE P2) --------
# Frontend Sentry — DSN from Sentry → Project → Client Keys.
# Leave empty in dev: SDK is fully no-op when DSN is absent.
VITE_SENTRY_DSN=

# Frontend PostHog — project key + EU host por padrão (LGPD-friendly).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.posthog.com

# Edge function Sentry — separate DSN so server traces stay isolated from
# client. Set via `supabase secrets set SENTRY_DSN_EDGE=...` in prod.
# SENTRY_DSN_EDGE=

# -------- Sightengine (SERVER-SIDE, set via `supabase secrets set`) --------
# Used by the moderate_photo edge function (pre-upload check) for Apple
# Guideline 1.2 compliance. Get keys at https://sightengine.com.
# If unset, the function fails-open (logs decision='unconfigured').
# SIGHTENGINE_USER=your-api-user
# SIGHTENGINE_SECRET=your-api-secret

# -------- Optional: legacy backend --------
# Only set if the deprecated Express backend (backend/) is still running.
# Frontend talks to Supabase exclusively in the current flow; leave unset.
# VITE_API_URL=https://api.beija.app
# VITE_SOCKET_URL=https://api.beija.app

# Beija — fastlane configuration (PLACEHOLDER)
#
# Most lanes are commented out until credentials are wired in the CI env. To
# run locally:
#
#   gem install bundler
#   bundle init && bundle add fastlane
#   bundle exec fastlane ios beta        # TestFlight
#   bundle exec fastlane android playstore  # Internal testing track
#
# Required env vars (typically loaded from CI secrets):
#   --- iOS ---
#   APP_STORE_CONNECT_API_KEY_ID
#   APP_STORE_CONNECT_API_ISSUER_ID
#   APP_STORE_CONNECT_API_KEY (path to .p8 or base64 contents)
#   FASTLANE_USER
#   FASTLANE_PASSWORD (app-specific password)
#   --- Android ---
#   BEIJA_KEYSTORE_PATH
#   BEIJA_KEYSTORE_PASSWORD
#   BEIJA_KEY_ALIAS
#   BEIJA_KEY_PASSWORD
#   PLAY_STORE_JSON_KEY_PATH (path to Play Console service account JSON)

default_platform(:ios)

